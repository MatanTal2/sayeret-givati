rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // All writes are denied from client SDK.
    // Writes go through firebase-admin API routes which bypass rules.

    // Users — authenticated users can read
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Authorized personnel — open read for registration verification
    match /authorized_personnel/{documentId} {
      allow read: if true;
      allow write: if false;
    }

    // Admin config — authenticated read
    match /admin_config/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // OTP sessions — open read for registration before auth
    match /otp_sessions/{phoneNumber} {
      allow read: if true;
      allow write: if false;
    }

    // OTP rate limits — open read for registration before auth
    match /otp_rate_limits/{phoneNumber} {
      allow read: if true;
      allow write: if false;
    }

    // Equipment templates — authenticated read
    match /equipmentTemplates/{typeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Categories — authenticated read
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Subcategories — authenticated read
    match /subcategories/{subcategoryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Equipment items — authenticated read
    match /equipment/{equipmentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Notifications — user can only read their own
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Actions log — authenticated read
    match /actionsLog/{actionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Transfer requests — authenticated read
    match /transferRequests/{requestId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Unit announcements — authenticated read; create/delete by admin / officer / commander.
    // Writes go via client SDK until the firebase-admin migration lands.
    match /announcements/{announcementId} {
      function canPost() {
        let profile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return request.auth != null && (
          profile.userType == 'admin' ||
          profile.role == 'officer' ||
          profile.role == 'commander'
        );
      }
      allow read: if request.auth != null;
      allow create: if canPost()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.body is string;
      allow delete: if canPost();
      allow update: if false;
    }

    // Useful links — authenticated read. Writes seeded via Firestore console
    // until admin CRUD UI ships.
    match /useful_links/{linkId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Unit media — authenticated read. Writes seeded via Firestore console
    // until an admin upload UI ships.
    match /unit_media/{mediaId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
